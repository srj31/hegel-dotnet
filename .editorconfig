root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{fs,fsx}]
indent_size = 4

[*.{fsproj,csproj,props,targets,xml}]
indent_size = 2

[*.{json,yml,yaml,nix}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false
